# TODO: 將此檔案改名為 pyproject.toml
# TODO: 將 {country} 替換為您的國家代碼（如 jp, kr, th）
# TODO: 將 {Country} 替換為您的國家名稱（如 Japan, Korea, Thailand）

[project]
name = "{country}txgnn"  # TODO: 例如 jptxgnn, krtxgnn, thtxgnn
version = "0.1.0"
description = "{Country} drug repurposing predictions using TxGNN"  # TODO: 修改描述
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "beautifulsoup4>=4.14.3",
    "feedparser>=6.0.12",
    "lxml>=6.0.2",
    "numpy<3",
    "openai>=1.0.0",
    "pandas>=2.2.0",
    "pyyaml>=6.0.0",
    "pytest>=9.0.2",
    "requests>=2.32.5",
    "tqdm>=4.67.1",
]

[project.optional-dependencies]
dev = [
    "pytest-cov>=7.0.0",
    "responses>=0.25.8",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
